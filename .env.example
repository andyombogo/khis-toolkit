# DHIS2 / KHIS Connection
# For development/demo: use the public DHIS2 HMIS demo server
# Verified on 2026-03-27
# DHIS2_BASE_URL=https://demos.dhis2.org/hmis_dev
# DHIS2_USERNAME=demo_en
# DHIS2_PASSWORD=District1#

# For production: use Kenya KHIS (requires MOH credentials)
# DHIS2_BASE_URL=https://hiskenya.org/api
# DHIS2_USERNAME=your_khis_username
# DHIS2_PASSWORD=your_khis_password

# Dashboard
FLASK_SECRET_KEY=change-this-in-production
FLASK_ENV=development

# FastAPI
# Leave blank during local development if you want the API to run without auth.
KHIS_API_KEY=replace-this-for-production
