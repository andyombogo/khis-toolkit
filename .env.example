# DHIS2 / KHIS Connection
# For development/demo: use DHIS2 public play server
# DHIS2_BASE_URL=https://play.dhis2.org/demo
# DHIS2_USERNAME=admin
# DHIS2_PASSWORD=district

# For production: use Kenya KHIS (requires MOH credentials)
# DHIS2_BASE_URL=https://hiskenya.org/api
# DHIS2_USERNAME=your_khis_username
# DHIS2_PASSWORD=your_khis_password

# Dashboard
FLASK_SECRET_KEY=change-this-in-production
FLASK_ENV=development
